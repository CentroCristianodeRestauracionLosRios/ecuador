{
  "rules": {
    "imagenes":   { ".read": true, ".write": "auth != null" },
    "libros":     { ".read": true, ".write": "auth != null" },
    "chat": {
      ".read": true,
      "$msgId": {
        ".write": "auth != null && (!data.exists() || data.child('uid').val() === auth.uid || auth.token.email === 'haroldolmedoanchundia@gmail.com')"
      }
    },
    "usuarios": {
      ".read": "auth != null && auth.token.email === 'haroldolmedoanchundia@gmail.com'",
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && (auth.uid === $uid || auth.token.email === 'haroldolmedoanchundia@gmail.com')"
      }
    },
    "videos":      { ".read": true, ".write": "auth != null && auth.token.email === 'haroldolmedoanchundia@gmail.com'" },
    "inspiracion": { ".read": true, ".write": "auth != null && auth.token.email === 'haroldolmedoanchundia@gmail.com'" },
    "eventos": {
      ".read": true,
      ".write": "auth != null && auth.token.email === 'haroldolmedoanchundia@gmail.com'",
      "$id": {
        "rsvp": { "$uid": { ".write": "auth != null && auth.uid === $uid" } }
      }
    },
    "fcm_tokens": {
      ".read": "auth != null && auth.token.email === 'haroldolmedoanchundia@gmail.com'",
      ".write": "auth != null"
    },
    "game_progress": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'haroldolmedoanchundia@gmail.com')",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "game_ranking": {
      ".read": true,
      "$uid": { ".write": "auth != null && auth.uid === $uid" }
    },
    "trivia_ranking": {
      ".read": true,
      "$nivel": {
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    },
    "sopa_ranking": {
      ".read": true,
      "$tema": {
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    },
    "memory_ranking": {
      ".read": true,
      "$nivel": {
        "$uid": { ".write": "auth != null && auth.uid === $uid" }
      }
    },
    "rpg2": {
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || auth.token.email === 'haroldolmedoanchundia@gmail.com')",
        ".write": "auth != null && auth.uid === $uid"
      }
    }
  }
}